# Server
NODE_ENV=development
PORT=5001
LOG_LEVEL=info
DEBUG_ENABLED=0
READ_ONLY_MODE=false

# Supabase runtime
VITE_SUPABASE_URL=https://your-project.supabase.co
SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
DATABASE_URL=postgresql://postgres:password@host:6543/postgres

# Build / release metadata
VITE_APP_VERSION=local-dev
COMMIT_SHA=local
BUILD_TIME=1970-01-01T00:00:00.000Z

# Feature flags
VITE_FEATURE_OFFLINE_QUEUE=false
VITE_FEATURE_OFFLINE_BADGE=false
VITE_OFFLINE_DEVICE_WHITELIST=
VITE_FEATURE_AUTH_BYPASS=true
VITE_FEATURE_AUTH_ROUTE_GUARDS=false
VITE_FEATURE_LOGGER_ADAPTER=false
VITE_FEATURE_MONITORING=false
VITE_OFFLINE_VALIDATION_ENABLED=true

# Optional monitoring
SENTRY_DSN=
