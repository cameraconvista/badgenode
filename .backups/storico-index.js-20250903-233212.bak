/* AUTO-BOOT storico */
(function () {
  const boot = () => {
    try {
      const qs = new URLSearchParams(location.search);
      const pin =
        qs.get('pin') || qs.get('pin1') || qs.get('pin_utente') || qs.get('pinUtente') || '';

      // Prova le inizializzazioni più probabili, nell'ordine
      if (typeof initStorico    === 'function') { initStorico(pin);    return; }
      if (typeof caricaStorico  === 'function') { caricaStorico(pin);  return; }
      if (typeof loadStorico    === 'function') { loadStorico(pin);    return; }
      if (typeof renderStorico  === 'function') { renderStorico(pin);  return; }
      if (typeof main           === 'function') { try { main(); } catch (_) {} }
    } catch (e) {
      console.error('BOOT storico error:', e);
    }
  };

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', boot, { once: true });
  } else {
    boot();
  }
})();
