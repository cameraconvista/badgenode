})();
 /* === /PATCH STORICO === */

// ===== Patch robusta storico =====
(() => {
  if (window.__storicoBootstrapped) return;
  window.__storicoBootstrapped = true;

  const once = (fn) => { let done=false; return (...a)=>{ if(!done){ done=true; try{fn(...a);}catch(e){console.error(e);} } } };
  const qs  = (s, r=document) => r.querySelector(s);

  // PIN dall'URL o da eventuali data-attr
  function getPin() {
    try {
      const u = new URL(location.href);
      return u.searchParams.get('pin') || qs('[data-pin]')?.dataset.pin || null;
    } catch { return null; }
  }

  // Back "intelligente"
  function goBack(ev){
    try{ ev?.preventDefault?.(); }catch{}
    const ref = document.referrer || "";
    if (ref && !/storico\.html/i.test(ref)) { history.back(); return; }
    // fallback
    location.href = 'utenti.html';
  }
  // Espongo anche globalmente per eventuali onclick inline residui
  window.goBackStorico = goBack;

  // Delegato super tollerante: .back, .indietro, [data-action=back], aria-label*="torna/indietro"
  const BACK_SEL = '[data-action="back"], .indietro, .back, [aria-label*="torna" i], [aria-label*="indietro" i], a[href="#indietro"]';
  document.addEventListener('click', (e) => {
    const t = e.target.closest?.(BACK_SEL);
    if (t) goBack(e);
  }, true);

  // Bootstrap: prova le funzioni se presenti, altrimenti "stimola" i filtri
  const boot = once(() => {
    const pin = getPin();
    try {
      if (typeof window.caricaStorico === 'function') { window.caricaStorico(pin); return; }
      if (typeof window.initStorico   === 'function') { window.initStorico(pin);   return; }
      if (typeof window.renderStorico === 'function') { window.renderStorico(pin); return; }
      // Fallback: triggerai change sui controlli per far scattare eventuali listeners già in pagina
      const sel = qs('select'); sel && sel.dispatchEvent(new Event('change', {bubbles:true}));
      const d1  = qs('input[type="date"]'); d1 && d1.dispatchEvent(new Event('change', {bubbles:true}));
    } catch (e) {
      console.error('bootstrap storico failed:', e);
    }
  });

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', boot, {once:true});
  } else {
    boot();
  }

  // Diagnostica veloce dalla console
  window.__storicoDiag = () => ({
    pin: getPin(),
    has: {
      caricaStorico: typeof window.caricaStorico,
      initStorico:   typeof window.initStorico,
      renderStorico: typeof window.renderStorico
    },
    backBtnFound: !!qs(BACK_SEL)
  });

})();
